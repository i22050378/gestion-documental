# ============================================================
#  Variables de entorno - Sistema de Gestion Documental
#  Copia este archivo como .env (dentro de la carpeta docker).
#  Cambia las contrasenas antes de usar en produccion.
# ============================================================

# --- Puertos expuestos en tu maquina (host) ---
# Si alguno choca con algo que ya tengas, cambialo (ej. 1434:1433).
MSSQL_PORT=1433
POSTGRES_PORT=5432
MONGO_PORT=27017

# --- SQL Server (Modulo Central / .NET) ---
# La contrasena SA debe ser FUERTE: 8+ caracteres con mayuscula,
# minuscula, numero y simbolo. Si no, el contenedor no arranca.
MSSQL_SA_PASSWORD=Str0ng!Passw0rd_2026
MSSQL_PID=Developer

# --- PostgreSQL (Modulo de Consulta / PHP) ---
POSTGRES_USER=appuser
POSTGRES_PASSWORD=Postgr3s!2026
POSTGRES_DB=consulta_db

# --- MongoDB (Modulo de Indexacion / Node) ---
MONGO_INITDB_ROOT_USERNAME=mongoadmin
MONGO_INITDB_ROOT_PASSWORD=M0ngo!2026
MONGO_INITDB_DATABASE=indexacion_db
