@{
    ViewData["Title"] = "Inicio";
}

<div class="card">
    <h2>Bienvenido, @ViewData["Nombre"]</h2>
    <p>Rol: <strong>@ViewData["Rol"]</strong></p>
    <p>Empresa: <strong>@ViewData["Empresa"]</strong></p>

    @if (User.IsInRole("Admin"))
    {
        <p>Como Admin, usa el menu de arriba para gestionar <strong>Usuarios</strong> y <strong>Empresas</strong>, y para ver los <strong>Documentos</strong> de todas las empresas.</p>
    }
    else if (User.IsInRole("Supervisor"))
    {
        <p>Entra a <strong>Documentos</strong> para crear y subir documentos de tu empresa.</p>
    }
    else if (User.IsInRole("Revisor"))
    {
        <p>Entra a <strong>Documentos</strong> para <strong>revisar</strong> los documentos pendientes y pasarlos al Aprobador.</p>
    }
    else if (User.IsInRole("Aprobador"))
    {
        <p>Entra a <strong>Documentos</strong> para dar la <strong>aprobacion final</strong> a los documentos ya revisados.</p>
    }
    else
    {
        <p>Entra a <strong>Documentos</strong> para consultar y descargar los documentos de tu empresa.</p>
    }
</div>
