<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestion Documental</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 0; background: #f5f5f4; color: #1c1c1a; }
        header { background: #2d2b55; color: #fff; padding: 16px 24px; }
        header h1 { margin: 0; font-size: 20px; }
        main { max-width: 900px; margin: 24px auto; padding: 0 16px; }
        h2 { font-size: 17px; margin-top: 0; }
        table { border-collapse: collapse; width: 100%; background: #fff; }
        th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #e5e5e5; font-size: 14px; }
        th { background: #efeef7; }
        .ok { color: #166534; font-weight: 600; }
        .err { color: #991b1b; font-weight: 600; }
        .card { background: #fff; border: 1px solid #e5e5e5; border-radius: 8px; padding: 16px; margin-bottom: 20px; }
        pre { white-space: pre-wrap; background: #fafaf9; padding: 10px; border-radius: 6px; }
    </style>
</head>
<body>
    <header><h1>Sistema de Gestion Documental</h1></header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
