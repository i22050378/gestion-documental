<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestion Documental</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 0; background: #f5f5f4; color: #1c1c1a; }
        header { background: #2d2b55; color: #fff; padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; }
        header h1 { margin: 0; font-size: 19px; }
        header .user { font-size: 14px; }
        header .user form { display: inline; margin-left: 10px; }
        header .user button.link { color: #cfcdf0; }
        nav.menu { background: #3b3866; padding: 8px 24px; }
        nav.menu a { color: #cfcdf0; margin-right: 18px; text-decoration: none; font-size: 14px; }
        nav.menu a:hover { text-decoration: underline; }
        main { max-width: 980px; margin: 24px auto; padding: 0 16px; }
        h2 { font-size: 17px; margin-top: 0; }
        .ok { color: #166534; font-weight: 600; }
        .err { color: #991b1b; font-weight: 600; font-size: 13px; }
        .card { background: #fff; border: 1px solid #e5e5e5; border-radius: 8px; padding: 16px; margin-bottom: 20px; }
        table { border-collapse: collapse; width: 100%; background: #fff; }
        th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #e5e5e5; font-size: 14px; }
        th { background: #efeef7; }
        .input { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
        .btn { background: #2d2b55; color: #fff; border: none; padding: 9px 18px; border-radius: 6px; cursor: pointer; font-size: 14px; display: inline-block; text-decoration: none; }
        .link { background: none; border: none; color: #2d2b55; cursor: pointer; text-decoration: underline; font-size: 13px; padding: 0; margin-left: 8px; }
        label { font-size: 14px; }
        .badge { display:inline-block; padding:2px 8px; border-radius:10px; font-size:12px; background:#efeef7; color:#3b3866; }
    </style>
</head>
<body>
    <header>
        <h1>Sistema de Gestion Documental</h1>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="user">
                @User.Identity.Name
                <form method="post" asp-controller="Account" asp-action="Logout">
                    <button type="submit" class="link">Cerrar sesion</button>
                </form>
            </span>
        }
    </header>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="menu">
            <a asp-controller="Home" asp-action="Index">Inicio</a>
            <a asp-controller="Documentos" asp-action="Index">Documentos</a>
            @await Component.InvokeAsync("NotificacionesBadge")
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                <a asp-controller="Empresas" asp-action="Index">Empresas</a>
            }
        </nav>
    }

    <main>
        @RenderBody()
    </main>
</body>
</html>
