@model List<Central.Models.BitacoraRow>
@{
    ViewData["Title"] = "Bitacora";
    bool esAdmin = (bool)(ViewData["EsAdmin"] ?? false);
}

<div class="card">
    <h2>Bitacora de actividad</h2>
    <p style="font-size:13px;color:#555;">
        @if (esAdmin) { <text>Mostrando la actividad de todas las empresas (ultimas 300).</text> }
        else if (User.IsInRole("Director")) { <text>Mostrando la actividad de tu empresa (ultimas 300).</text> }
        else { <text>Mostrando tu actividad (ultimas 300).</text> }
    </p>

    @if (!Model.Any())
    {
        <p>Aun no hay actividad registrada.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Fecha y hora</th>
                    <th>Usuario</th>
                    <th>Accion</th>
                    <th>Entidad</th>
                    <th>Detalle</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.FechaHora.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@e.Usuario</td>
                        <td><span class="badge">@e.Accion</span></td>
                        <td>@(e.Entidad)@(e.IdEntidad != null ? $" #{e.IdEntidad}" : "")</td>
                        <td>@e.Detalle</td>
                        <td style="font-size:12px;color:#888;">@e.DireccionIP</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
