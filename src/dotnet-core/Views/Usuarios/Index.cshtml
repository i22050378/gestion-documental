@model List<Central.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="card">
    <h2>Usuarios</h2>
    <p><a class="btn" asp-controller="Usuarios" asp-action="Create">Nuevo usuario</a></p>
    <table>
        <thead>
            <tr><th>Id</th><th>Nombre</th><th>Correo</th><th>Rol</th><th>Empresa</th><th>Activo</th><th>Acciones</th></tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.IdUsuario</td>
                    <td>@u.NombreCompleto</td>
                    <td>@u.Correo</td>
                    <td>@(u.Rol?.Nombre)</td>
                    <td>@(u.Empresa?.Nombre ?? "(global)")</td>
                    <td>@(u.Activo ? "Si" : "No")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@u.IdUsuario">Editar</a>
                        <form method="post" asp-action="ToggleActivo" asp-route-id="@u.IdUsuario" style="display:inline;">
                            <button type="submit" class="link">@(u.Activo ? "Desactivar" : "Activar")</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
