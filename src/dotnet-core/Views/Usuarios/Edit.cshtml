@model Central.Models.UsuarioFormViewModel
@{
    ViewData["Title"] = "Editar usuario";
}

<div class="card" style="max-width: 480px;">
    <h2>Editar usuario</h2>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <p class="err">@Model.Error</p>
    }

    <form method="post" asp-controller="Usuarios" asp-action="Edit">
        <input type="hidden" asp-for="IdUsuario" />
        <div style="margin-bottom: 10px;">
            <label>Nombre completo</label>
            <input asp-for="NombreCompleto" class="input" />
            <span asp-validation-for="NombreCompleto" class="err"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Correo</label>
            <input asp-for="Correo" class="input" />
            <span asp-validation-for="Correo" class="err"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Nueva contrasena (opcional)</label>
            <input asp-for="Contrasena" type="password" class="input" placeholder="Dejar vacio para no cambiarla" />
        </div>
        <div style="margin-bottom: 10px;">
            <label>Rol</label>
            <select asp-for="IdRol" class="input" asp-items="@(new SelectList(Model.Roles, "IdRol", "Nombre"))"></select>
            <span asp-validation-for="IdRol" class="err"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Empresa (dejar vacio si el rol es Admin)</label>
            <select asp-for="IdEmpresa" class="input" asp-items="@(new SelectList(Model.Empresas, "IdEmpresa", "Nombre"))">
                <option value="">(ninguna)</option>
            </select>
        </div>
        <div style="margin-bottom: 14px;">
            <label><input type="checkbox" asp-for="Activo" /> Activo</label>
        </div>
        <button type="submit" class="btn">Guardar</button>
        <a asp-action="Index" style="margin-left:10px;">Cancelar</a>
    </form>
</div>
